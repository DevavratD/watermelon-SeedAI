# ─────────────────────────────────────────────────────────────────────
# Sentinel — Environment Variables
# Copy this file to .env and fill in your values
# ─────────────────────────────────────────────────────────────────────

# ── Supabase ──────────────────────────────────────────────────────────
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Direct PostgreSQL connection (Supabase) etc can be configured here:
# DATABASE_URL=postgresql+psycopg2://postgres:<pw>@db.<ref>.supabase.co:5432/postgres
DATABASE_URL=sqlite:///sentinel.db

# ── App ───────────────────────────────────────────────────────────────
APP_NAME=Sentinel
APP_VERSION=1.0.0
SECRET_KEY=change-this-to-a-random-secret-key
DEBUG=false
GEMINI_API_KEY=your_gemini_api_key_here

# ── ML Model ──────────────────────────────────────────────────────────
ML_MODEL_PATH=./ml_pipeline/artifacts/isolation_forest.pkl
ML_SCALER_PATH=./ml_pipeline/artifacts/scaler.pkl
ML_COLD_START_SCORE=0.3

# ── Risk Score Thresholds ─────────────────────────────────────────────
ALLOW_THRESHOLD=40
BLOCK_THRESHOLD=75

# ── Rules Engine ──────────────────────────────────────────────────────
HIGH_AMOUNT_MULTIPLIER=3.0
VELOCITY_WINDOW_MINUTES=60
VELOCITY_SPIKE_THRESHOLD=5
UNUSUAL_HOUR_START=0
UNUSUAL_HOUR_END=5

# ── Feedback / Retraining ─────────────────────────────────────────────
RETRAIN_FEEDBACK_THRESHOLD=50
